# Database (Supabase PostgreSQL - use pooled connection for Vercel)
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string (PGBouncer port 6543)
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

NEXTAUTH_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
NEXTAUTH_URL="https://your-app.vercel.app"
JWT_SECRET="generate-with: node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""

# Puter.js is used for AI features (article generation, image gen)
# No API key needed - users must be logged into Puter.com in browser

# Optional OAuth providers (leave blank to use credentials-only auth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
